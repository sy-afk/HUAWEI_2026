# Copy this file to .env and fill in your values (never commit .env)
BOT_TOKEN=paste_token_from_BotFather_here
APP_URL=https://your-safespace-link.example.com

# Share of drills sent as an image (from your own screenshots in images/).
# 0.0 = text only, 1.0 = always image when images exist. Default 0.5.
POSTER_PROBABILITY=0.5

# Optional: change the trending-scams feed or cadence.
# TRENDING_URL=https://www.scamalert.sg/stories
# TRENDING_INTERVAL_SECONDS=604800
