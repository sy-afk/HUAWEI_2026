# SafeSpace backend — copy to .env (gitignored). Only needed to fire REAL calls.

# The drill target (your own verified mobile, E.164). Used if a user has no phone on file.
MY_MOBILE=

# Vapi (from the voice POC). Without these, real /fire calls error — but the app,
# practice drills, and the /simulate demo loop all work without them.
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# Optional voice tuning (defaults: azure Singapore-English "Wayne")
VAPI_VOICE_PROVIDER=azure
VAPI_VOICE_ID=en-SG-WayneNeural
VAPI_CLAUDE_MODEL=
MAX_DURATION_SECONDS=300

# Shared secret proving an end-of-call report really came from Vapi. REQUIRED for the
# webhook to accept anything — without it /api/webhooks/vapi refuses (503), because that
# route mutates a user's training record and is internet-facing by design.
# Generate one: openssl rand -hex 32
VAPI_WEBHOOK_SECRET=

# Registers /api/drills/simulate, which writes REAL drill results for the caller.
# Offline-demo only — NEVER enable in a deployed environment.
ENABLE_DEMO_ROUTES=

# Public tunnel base URL so Vapi can reach the end-of-call webhook (real outcomes -> XP).
# e.g. after `cloudflared tunnel --url http://localhost:3000`  ->  https://xxxx.trycloudflare.com
# Leave blank to run without live webhooks (use /api/drills/simulate to demo the loop).
PUBLIC_URL=

# Twilio Verify — for the in-app phone-registration OTP. Set ALL THREE for real SMS codes.
# If any is missing, verification FAILS CLOSED (503) unless ALLOW_DEV_VERIFY=true below.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Offline/demo escape hatch: accept the fixed bypass code 000000 instead of real SMS.
# MUST be opted into deliberately — NEVER set this in production. Leaving it unset means a
# missing/typo'd TWILIO_* var can never silently downgrade to "accept 000000 from anyone".
ALLOW_DEV_VERIFY=

# Which seeded user the demo acts as
DRILL_USER=you
PORT=3000

# ── Email drill ──────────────────────────────────────────────────────────
# Both required, else /api/drills/email refuses (503). Email is only ever sent
# to the SESSION USER'S OWN stored address — never one named in a request.
OPENAI_API_KEY=
GOOGLE_SCRIPT_URL=

# ── SMS drill ────────────────────────────────────────────────────────────
# SMS-capable Twilio number to send drills FROM. Blank = /api/drills/sms refuses (503).
TWILIO_SMS_FROM=
# Delay before the guaranteed reveal SMS (ms). Default 120000.
SMS_REVEAL_DELAY_MS=
# Shared secret the Apps Script checks (its SAFESPACE_SECRET script property).
# REQUIRED — without it the sender is an open relay, so we refuse to send.
GOOGLE_SCRIPT_SECRET=
