# email-webapp — copy to .env.local (gitignored). Never commit real values.

# ── CONSENT GATE (required) ──────────────────────────────────────────────
# Comma/whitespace-separated addresses allowed to RECEIVE a drill phishing email.
# FAILS CLOSED: empty/unset = sends to nobody (503). This is what stops the app
# being an open phishing relay — only put addresses here that have explicitly
# opted in to being drilled.
DRILL_EMAIL_ALLOWLIST=

# ── Sending ──────────────────────────────────────────────────────────────
# Google Apps Script web-app URL that performs the actual send.
GOOGLE_SCRIPT_URL=

# ── AI ───────────────────────────────────────────────────────────────────
# Generates the phishing email body (gpt-4o-mini).
OPENAI_API_KEY=
