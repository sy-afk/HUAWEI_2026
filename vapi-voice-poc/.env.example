# SafeSpace Voice POC — copy to .env and fill in (never commit .env)

# --- Required ---
# Vapi private API key (Vapi dashboard -> API Keys)
VAPI_API_KEY=

# The phoneNumberId of your imported Twilio number in Vapi
# (Vapi dashboard -> Phone Numbers -> click your number -> copy its ID, NOT the +65 digits)
VAPI_PHONE_NUMBER_ID=

# The number to call — YOUR OWN mobile, E.164 format, e.g. +6591234567
# On a Twilio trial this MUST be a Verified Caller ID.
MY_MOBILE=

# --- Optional / tunable (sensible defaults in call.py if left blank) ---
# Claude model id as Vapi exposes it. Prefer a FAST (Haiku-class) model for natural turn-taking.
# If the default in call.py is rejected, check Vapi dashboard -> Model for the exact current string.
VAPI_CLAUDE_MODEL=

# Voice provider: "11labs" (ElevenLabs, US-accent default) or "azure" (Singapore-English voices), etc.
VAPI_VOICE_PROVIDER=

# Voice id. azure Singapore English: en-SG-LunaNeural (F) / en-SG-WayneNeural (M). 11labs: preset name or voice id.
VAPI_VOICE_ID=

# Voice naturalness knobs (blank = sensible defaults set in call.py). Fixes the "robot" sound:
#   VAPI_VOICE_MODEL     eleven_turbo_v2_5 | eleven_multilingual_v2 | eleven_flash_v2_5 ...
#   VAPI_VOICE_STABILITY 0..1  LOWER = more natural human variation; HIGHER = monotone
#   VAPI_VOICE_SIMILARITY 0..1 closeness to the source voice
#   VAPI_VOICE_STYLE     0..1  expressiveness (keep <= 0.4 to avoid distortion)
VAPI_VOICE_MODEL=
VAPI_VOICE_STABILITY=
VAPI_VOICE_SIMILARITY=
VAPI_VOICE_STYLE=

# Prosody knobs (azure + 11labs). SPEED ~0.7–1.2 (0.92 = a touch slower, less robotic); PITCH -12..12 semitones.
VAPI_VOICE_SPEED=
VAPI_VOICE_PITCH=

# Which persona file under persona/ to use for the call.
PERSONA_FILE=persona/govt_impersonation.md

# Hard cap on call length (seconds). Twilio trial also caps at 600s.
MAX_DURATION_SECONDS=300

# Optional: bring-your-own Anthropic key for later (NOT needed for Vapi-managed Claude).
ANTHROPIC_API_KEY=
